# Core app settings
DJANGO_ENV=development
SECRET_KEY=replace-with-a-secure-random-secret
DEBUG=True
TIME_ZONE=America/New_York
ALLOWED_HOSTS=127.0.0.1,localhost
INTERNAL_IPS=127.0.0.1,localhost

# Production database (required when DJANGO_ENV=production)
DATABASE_URL=postgres://username:password@localhost:5432/dbname
DATABASE_SSL_REQUIRE=False
USE_X_FORWARDED_HOST=True
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
CSRF_COOKIE_HTTPONLY=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_REFERRER_POLICY=same-origin
X_FRAME_OPTIONS=DENY

# Production email (required when DJANGO_ENV=production)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@example.com
SERVER_EMAIL=server@example.com
EMAIL_ADMIN=admin@example.com

# AI inference settings
AI_INFERENCE_BASE_URL=http://127.0.0.1:11434/v1
AI_MODEL_ID=llama3.2
AI_REQUEST_TIMEOUT_SECONDS=300.0
AI_MAX_TOKENS=4096
AI_API_KEY=your-api-key